# The Meme Company - Environment Variables

# Your token's mint address (paste after launch)
NEXT_PUBLIC_TOKEN_MINT=

# Company treasury wallet (receives fees, sends distributions)
NEXT_PUBLIC_TREASURY_WALLET=

# Solana RPC - get a paid one from Helius/QuickNode for production
# Free public RPCs will rate-limit you on holder snapshots
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=

# Admin wallets (comma-separated) - allowed to create votes & distributions
ADMIN_WALLETS=

# Minimum % of supply required to vote (as decimal: 0.05% = 0.0005)
NEXT_PUBLIC_VOTING_THRESHOLD=0.0005

# Top N holders who receive distributions
NEXT_PUBLIC_TOP_HOLDERS_COUNT=100

# Unix timestamp (ms) of token launch — sets the countdown
# Run: Date.now() in browser console at exact launch moment and paste here
NEXT_PUBLIC_LAUNCH_TIME=

# Treasury private key (base58) — NEVER commit this, keep in .env.local only
TREASURY_PRIVATE_KEY=
